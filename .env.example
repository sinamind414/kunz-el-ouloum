# Kunz El Ouloum — variables d'environnement (exemple)
# Le tuteur intelligent est 100% local (offline-first) : AUCUNE clé n'est requise pour l'app.
# Les variables ci-dessous sont OPTIONNELLES et n'activent que l'auth + la télémétrie Supabase.
# Copiez ce fichier en .env.local et remplacez les placeholders par vos vraies valeurs.

# URL de votre projet Supabase (optionnel)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé anonyme publique Supabase (optionnel) — jamais de clé service_role côté client
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...placeholder
